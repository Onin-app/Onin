{
  "name": "create-onin-plugin",
  "version": "0.1.0",
  "private": false,
  "description": "CLI for scaffolding Onin plugins with lifecycle and release packaging built in.",
  "license": "GPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "create-onin-plugin": "./dist/cli.js"
  },
  "files": [
    "README.md",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "start": "pnpm run build && node ./dist/cli.js",
    "test": "pnpm run build && node --test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
