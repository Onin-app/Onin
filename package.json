{
  "name": "onin-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Onin monorepo - App, SDK and Demo",
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter app tauri:dev",
    "dev:demo": "pnpm --filter plugin-demo dev",
    "build": "pnpm -r build",
    "build:inject": "pnpm --filter onin-inject build",
    "build:app": "pnpm --filter onin-inject build && pnpm --filter app tauri:build",
    "build:sdk": "pnpm --filter onin-sdk build",
    "build:demo": "pnpm --filter plugin-demo build",
    "create:plugin": "pnpm --filter create-onin-plugin start",
    "test": "pnpm -r test",
    "test:sdk": "pnpm --filter onin-sdk test",
    "check": "pnpm --filter app --filter onin-inject check",
    "format": "prettier --write \"packages/**/*.{ts,svelte,json}\" && cargo fmt --manifest-path packages/app/src-tauri/Cargo.toml",
    "tauri": "cd packages/app && pnpm tauri",
    "tauri:dev": "pnpm --filter app tauri:dev",
    "tauri:build": "pnpm --filter app tauri:build",
    "release": "pnpm --filter app release",
    "docs:dev": "pnpm --filter onin-docs dev",
    "docs:build": "pnpm --filter onin-docs build",
    "docs:preview": "pnpm --filter onin-docs preview",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {}
  }
}
